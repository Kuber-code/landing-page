---
import { t } from '@i18n';
import type { Locale } from '@/types';
import { Button, Link, Eyebrow } from '@components/ui';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="cta" id="contact">
  <div class="cta__inner reveal">
    <Eyebrow>{t(locale, 'cta.eyebrow')}</Eyebrow>
    <h2>{t(locale, 'cta.title')}</h2>
    <p>{t(locale, 'cta.sub')}</p>
    <Button href={`mailto:agnieszka.wolczyk@gmail.com?subject=${encodeURIComponent('Meeting booking request')}`} variant="invert">{t(locale, 'cta.book30')}</Button>
    <Link href="mailto:agnieszka.wolczyk@gmail.com">{t(locale, 'cta.email')}</Link>
  </div>
</section>

<style>
  .cta {
    background: var(--invert-bg);
    color: var(--invert-fg);
    text-align: center;
  }
  .cta__inner {
    max-width: 920px;
    margin: 0 auto;
    padding: 0 var(--pad-x);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
  }
  .cta h2 { font-size: clamp(48px, 6vw, 88px); color: var(--invert-fg); }
  .cta p {
    color: var(--invert-muted);
    max-width: 56ch;
    font-size: clamp(16px, 1.3vw, 19px);
    margin: 0;
  }
  .cta :global(.text-link) {
    color: var(--invert-muted);
    border-bottom-color: color-mix(in oklab, var(--invert-fg) 25%, transparent);
  }
  .cta :global(.text-link:hover) {
    color: var(--invert-fg);
    border-bottom-color: var(--invert-fg);
  }
</style>
