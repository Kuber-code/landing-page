---
import { t } from '@i18n';
import type { Locale } from '@/types';

interface Props { locale: Locale }
const { locale } = Astro.props;

const items = [
  { n: '01', t: t(locale, 'spec.1.t'), d: t(locale, 'spec.1.d') },
  { n: '02', t: t(locale, 'spec.2.t'), d: t(locale, 'spec.2.d') },
  { n: '03', t: t(locale, 'spec.3.t'), d: t(locale, 'spec.3.d') },
  { n: '04', t: t(locale, 'spec.4.t'), d: t(locale, 'spec.4.d') },
];
---

<section id="specs">
  <div class="container">
    <div class="section-head reveal">
      <h2>{t(locale, 'specs.title')}</h2>
      <div class="meta">{t(locale, 'specs.meta')}</div>
    </div>
  </div>

  <div class="container">
    <div class="specs reveal">
      {
        items.map((it) => (
          <article class="spec">
            <span class="spec__top"></span>
            <span class="spec__num">{it.n}</span>
            <h3 class="spec__title">{it.t}</h3>
            <p class="spec__desc">{it.d}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .specs {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .spec {
    background: var(--bg);
    padding: 48px 36px 56px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
    transition: background 0.3s var(--ease);
  }
  .spec:hover { background: color-mix(in oklab, var(--accent) 8%, var(--bg)); }
  .spec__num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .spec__title { font-size: clamp(28px, 3vw, 42px); }
  .spec__desc { color: var(--fg-muted); max-width: 38ch; margin: 0; }
  .spec__top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s var(--ease);
  }
  .spec:hover .spec__top { transform: scaleX(1); }

  @media (max-width: 768px) {
    .specs { grid-template-columns: 1fr; }
  }
</style>
