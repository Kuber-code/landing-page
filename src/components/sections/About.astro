---
import { Image } from 'astro:assets';
import { t } from '@i18n';
import type { Locale } from '@/types';
import portrait from '@/assets/portrait.jpg';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section id="about">
  <div class="container">
    <div class="section-head reveal">
      <h2>{t(locale, 'about.title')}</h2>
      <div class="meta">{t(locale, 'about.meta')}</div>
    </div>

    <div class="about__grid">
      <div class="about__photo media reveal">
        <Image
          src={portrait}
          alt="Agnieszka Wołczyk"
          widths={[360, 720, 1075]}
          sizes="(max-width: 1024px) 360px, 32vw"
          loading="lazy"
        />
      </div>

      <div class="about__body reveal">
        <p class="about__lead">{t(locale, 'about.p1')}</p>
        <p>{t(locale, 'about.p2')}</p>

        <div class="about__stats">
          <div class="stat">
            <div class="stat__num" data-count="15">0</div>
            <div class="stat__label">{t(locale, 'stat.years')}</div>
          </div>
          <div class="stat">
            <div class="stat__num" data-count="40" data-suffix="+">0</div>
            <div class="stat__label">{t(locale, 'stat.projects')}</div>
          </div>
          <div class="stat">
            <div class="stat__num" data-count="12">0</div>
            <div class="stat__label">{t(locale, 'stat.cities')}</div>
          </div>
        </div>

        <a class="text-link about__cv" href="/cv.pdf" download="CV_Agnieszka_Wolczyk.pdf">
          <span>{t(locale, 'about.cv')}</span>
          <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: var(--gap-wide);
    align-items: start;
  }
  .about__photo { aspect-ratio: 3/4; position: relative; }
  .about__body { display: flex; flex-direction: column; gap: 28px; }
  .about__body p {
    font-size: clamp(17px, 1.3vw, 20px);
    line-height: 1.65;
    margin: 0;
    max-width: 60ch;
    text-wrap: pretty;
  }
  .about__lead::first-letter {
    font-family: var(--serif);
    font-size: 5em;
    float: left;
    line-height: 0.85;
    padding: 8px 12px 0 0;
    color: var(--accent);
  }
  .about__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap);
    margin-top: 12px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
  }
  .stat__num {
    font-family: var(--serif);
    font-size: clamp(48px, 5vw, 76px);
    line-height: 1;
    font-feature-settings: 'tnum' 1;
  }
  .stat__label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-top: 8px;
  }
  .about__cv {
    align-self: flex-start;
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--rule);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.25s var(--ease), color 0.25s var(--ease);
  }
  .about__cv:hover { border-color: var(--fg); }
  .about__cv .arrow { display: inline-block; transition: transform 0.25s var(--ease); }
  .about__cv:hover .arrow { transform: translateX(4px); }

  /* ---- Tablet: stack portrait above text so the desktop range visibly responds ---- */
  @media (max-width: 1024px) {
    .about__grid { grid-template-columns: 1fr; gap: 48px; }
    .about__photo { max-width: 360px; }
  }

  @media (max-width: 768px) {
    .about__grid { grid-template-columns: 1fr; }
    .about__stats { grid-template-columns: repeat(3, 1fr); }
  }
</style>
