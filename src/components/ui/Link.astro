---
interface Props {
  href: string;
  class?: string;
  target?: string;
  rel?: string;
}
const { href, class: className = '', target, rel } = Astro.props;
---

<a class={`text-link ${className}`} href={href} {...(target && { target })} {...(rel && { rel })}>
  <span><slot /></span>
  <span class="arrow">→</span>
</a>

<style>
  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 3px;
    border-bottom: 1px solid var(--rule);
    font-size: 14px;
    letter-spacing: 0.02em;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.25s var(--ease), color 0.25s var(--ease);
  }
  .text-link:hover { border-color: var(--fg); }
  .arrow { display: inline-block; transition: transform 0.25s var(--ease); }
  .text-link:hover .arrow { transform: translateX(4px); }
</style>
