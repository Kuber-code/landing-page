---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<span class={`tag ${className}`}><slot /></span>

<style>
  .tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    padding: 6px 12px;
    border: 1px solid var(--rule);
    color: var(--fg-muted);
    display: inline-block;
  }
</style>
